<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @session.title %></h1>
      <p class="text-gray-500 text-sm mt-1"><%= @session.created_at.strftime("%Y-%m-%d %H:%M") %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= status_badge(@session.status) %>
      <%= button_to "실험 실행", run_session_path(@session), method: :post, class: "bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600" %>
    </div>
  </div>

  <%# 시스템 프롬프트 %>
  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <h2 class="font-semibold text-gray-700 mb-2">시스템 프롬프트</h2>
    <p class="text-gray-600"><%= @session.system_prompt %></p>
  </div>

  <%# 메시지 목록 %>
  <div class="mb-6">
    <h2 class="text-xl font-bold mb-4">User Query 목록</h2>

    <% if @session.messages.empty? %>
      <p class="text-gray-400 mb-4">아직 메시지가 없어요. 추가해보세요!</p>
    <% else %>
      <div class="space-y-2 mb-4">
        <% @session.messages.order(:position).each do |message| %>
          <div class="flex justify-between items-center border rounded-lg px-4 py-3">
            <p class="text-gray-700"><%= message.content %></p>
            <%= button_to "삭제", session_message_path(@session, message), method: :delete, class: "text-red-400 hover:text-red-600 text-sm", form: { data: { turbo_confirm: "삭제할까요?" } } %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# 메시지 추가 폼 %>
    <%= form_with url: session_messages_path(@session), class: "flex gap-2" do |f| %>
      <%= f.text_field :content, name: "message[content]", class: "flex-1 border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "User query를 입력하세요" %>
      <%= f.submit "추가", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 cursor-pointer" %>
    <% end %>
  </div>

<%# 실험 결과 테이블 %>
<% if @session.runs.any? %>
  <h2 class="text-xl font-bold mb-4">실험 결과</h2>

  <% models = @session.runs.pluck(:llm_model).uniq %>
  <% messages = @session.messages.order(:position) %>

  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="bg-gray-50">
          <th class="border px-4 py-3 text-left w-48">User Query</th>
          <% models.each do |model| %>
            <th class="border px-4 py-3 text-center text-blue-600"><%= model %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% messages.each do |message| %>
          <tr class="hover:bg-gray-50">
            <td class="border px-4 py-3 font-medium text-gray-700 align-top">
              <%= message.content %>
            </td>
            <% models.each do |model| %>
              <% run = @session.runs.find_by(message: message, llm_model: model) %>
              <td class="border px-4 py-3 align-top">
                <% if run %>
                  <p class="text-gray-700 text-xs mb-2"><%= run.response %></p>
                  <div class="flex justify-between text-xs text-gray-400">
                    <span>⏱ <%= run.latency_ms %>ms</span>
                    <% if run.judgement %>
                      <span class="font-semibold text-green-600">점수: <%= run.judgement.score %>/10</span>
                    <% end %>
                  </div>
                  <% if run.judgement %>
                    <p class="text-gray-400 text-xs mt-1">💬 <%= run.judgement.reasoning %></p>
                  <% end %>
                <% else %>
                  <span class="text-gray-300">-</span>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>